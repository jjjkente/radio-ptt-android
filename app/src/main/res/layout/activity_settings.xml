<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="top">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Server URL"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editServerUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textUri"
        android:hint="https://poc.jjjk.com.au"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This device's IMEI"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/textImei"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:text="Reading…"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter this IMEI when registering the radio in the admin dashboard."
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save &amp; Connect" />

</LinearLayout>
